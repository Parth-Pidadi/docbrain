# Copy this to .env and fill in your values

APP_ENV=development
SECRET_KEY=your-secret-key-here

# Groq API (get yours at https://console.groq.com)
GROQ_API_KEY=gsk_...

# PostgreSQL
DATABASE_URL=postgresql://docbrain:docbrain@localhost:5432/docbrain

# ChromaDB storage path
CHROMA_PERSIST_DIR=./chroma_db

# Upload storage path
UPLOAD_DIR=./uploads

# File size limit in MB
MAX_FILE_SIZE_MB=20

# Colab GPU inference server
# Run backend/DocBrain_GPU_Server.ipynb on Colab Pro, then paste the ngrok URL here
# Leave empty to use local CPU fallbacks (Tesseract + local BGE)
COLAB_URL=
